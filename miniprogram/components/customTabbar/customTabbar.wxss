.tabbar {
    position: fixed;
    bottom: 0;
    left: 0;
    right: 0;
    background-color: #fbf7ef;
    display: flex;
    border-top: 1px solid #e0e0e0;
    padding-top: 16px;
    padding-bottom: env(safe-area-inset-bottom);
}

.tab-item {
    flex: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    position: relative;
    z-index: 1;
}

.tab-icon {
    width: 24px;
    height: 24px;
    margin-bottom: 2px;
}

.tab-icon image {
    width: 100%;
    height: 100%;
}

.tab-text {
    font-size: 16px;
    color: #AAABB8;
    font-family: 'ZCool', serif;
}

.tab-item.selected .tab-text {
    color: #191a1b;
    font-weight: 700;
}

/* 选中时的背景效果 */
.tab-background {
    position: absolute;
    top: -30%;
    left: 10%;
    right: 10%;
    height: 150%;
    background-color: #adc4ae;
    border-radius: 8px;
    z-index: -1;
}
