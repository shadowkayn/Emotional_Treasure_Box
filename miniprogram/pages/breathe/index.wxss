.container {
  min-height: 100vh;
  background-image: linear-gradient(225deg, #A9C9CA 0%, #E8F1EF 100%);
  display: flex;
  flex-direction: column;
  align-items: center;
  padding-bottom: 180rpx;
  overflow: hidden;
  position: relative;
}

/* 标题 */
.header {
  margin-top: 80rpx;
  width: 100%;
  text-align: center;
  z-index: 3;
}

.title {
  font-size: 42rpx;
  font-weight: 700;
  color: #2c3e50;
  letter-spacing: 6rpx;
}

/* 呼吸球区域 */
.breath-area {
  margin-top: 100rpx;
  width: 500rpx;
  height: 500rpx;
  position: relative;
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 2;
}

/* ========== 横向波浪拉丝动画 ========== */
.silk-wave-wrap {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  pointer-events: none;
  overflow: hidden;
  z-index: 1;
}

.silk-line {
  position: absolute;
  left: -20%;
  width: 140%;
  height: 4rpx;
  border-radius: 4rpx;
  background: linear-gradient(
    90deg,
    transparent 0%,
    rgba(255,255,255,0.05) 10%,
    rgba(255,255,255,0.45) 30%,
    rgba(255,255,255,0.7) 50%,
    rgba(255,255,255,0.45) 70%,
    rgba(255,255,255,0.05) 90%,
    transparent 100%
  );
  filter: blur(1rpx);
  animation: silkFloat 6s ease-in-out infinite;
}

.silk-line-1 {
  top: 32%;
  height: 3rpx;
  opacity: 0.35;
  animation-duration: 7s;
  animation-delay: 0s;
}

.silk-line-2 {
  top: 40%;
  height: 5rpx;
  opacity: 0.55;
  animation-duration: 5.5s;
  animation-delay: -1s;
}

.silk-line-3 {
  top: 48%;
  height: 6rpx;
  opacity: 0.7;
  animation-duration: 6s;
  animation-delay: -2.5s;
}

.silk-line-4 {
  top: 52%;
  height: 5rpx;
  opacity: 0.6;
  animation-duration: 7.5s;
  animation-delay: -0.8s;
}

.silk-line-5 {
  top: 58%;
  height: 4rpx;
  opacity: 0.45;
  animation-duration: 6.5s;
  animation-delay: -3s;
}

.silk-line-6 {
  top: 44%;
  height: 3rpx;
  opacity: 0.3;
  animation-duration: 8s;
  animation-delay: -1.5s;
}

.silk-line-7 {
  top: 62%;
  height: 3rpx;
  opacity: 0.25;
  animation-duration: 7s;
  animation-delay: -4s;
}

@keyframes silkFloat {
  0% {
    transform: translateY(0rpx) scaleY(1);
  }
  20% {
    transform: translateY(-18rpx) scaleY(1.3);
  }
  40% {
    transform: translateY(12rpx) scaleY(0.8);
  }
  60% {
    transform: translateY(-8rpx) scaleY(1.15);
  }
  80% {
    transform: translateY(14rpx) scaleY(0.9);
  }
  100% {
    transform: translateY(0rpx) scaleY(1);
  }
}

/* 外层光晕 */
.glow {
  position: absolute;
  width: 420rpx;
  height: 420rpx;
  border-radius: 50%;
  background: radial-gradient(circle, rgba(255,255,255,0.6) 0%, rgba(255,255,255,0) 70%);
  transition: transform 4s ease-in-out, opacity 4s ease-in-out;
}

.glow.active {
  animation: glowPulse 8s ease-in-out infinite;
}

@keyframes glowPulse {
  0%, 100% {
    transform: scale(1);
    opacity: 0.4;
  }
  50% {
    transform: scale(1.3);
    opacity: 0.8;
  }
}

/* 呼吸球 */
.orb {
  width: 280rpx;
  height: 280rpx;
  border-radius: 50%;
  background: radial-gradient(circle at 40% 35%, rgba(255,255,255,0.95) 0%, rgba(210,230,240,0.7) 50%, rgba(180,210,225,0.4) 100%);
  box-shadow:
    0 0 60rpx rgba(255,255,255,0.8),
    0 0 120rpx rgba(200,225,240,0.4),
    inset 0 0 40rpx rgba(255,255,255,0.5);
  position: absolute;
  transition: transform 4s ease-in-out;
}

.orb.active {
  animation: orbBreathe 8s ease-in-out infinite;
}

@keyframes orbBreathe {
  0%, 100% {
    transform: scale(0.85);
    box-shadow:
      0 0 40rpx rgba(255,255,255,0.6),
      0 0 80rpx rgba(200,225,240,0.3),
      inset 0 0 30rpx rgba(255,255,255,0.4);
  }
  50% {
    transform: scale(1.15);
    box-shadow:
      0 0 80rpx rgba(255,255,255,0.9),
      0 0 160rpx rgba(200,225,240,0.5),
      inset 0 0 50rpx rgba(255,255,255,0.6);
  }
}

/* 内层光点 */
.orb-inner {
  position: absolute;
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  background: radial-gradient(circle, rgba(255,255,255,0.9) 0%, rgba(255,255,255,0) 70%);
}

.orb-inner.active {
  animation: innerPulse 8s ease-in-out infinite;
}

@keyframes innerPulse {
  0%, 100% {
    transform: scale(0.9);
    opacity: 0.6;
  }
  50% {
    transform: scale(1.2);
    opacity: 1;
  }
}

/* 提示文字 */
.hint-area {
  margin-top: 60rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  min-height: 120rpx;
  z-index: 3;
}

.hint-text {
  font-size: 36rpx;
  color: #3a5060;
  letter-spacing: 6rpx;
  font-weight: 600;
  transition: opacity 0.5s ease;
  line-height: 1.8;
}

.hint-text.fade {
  opacity: 0.3;
}

.hint-text.show {
  opacity: 1;
}

/* 时长选择 */
.duration-bar {
  margin-top: 60rpx;
  display: flex;
  gap: 20rpx;
  background: rgba(255,255,255,0.5);
  border-radius: 40rpx;
  padding: 8rpx;
  z-index: 3;
}

.duration-item {
  padding: 16rpx 36rpx;
  border-radius: 32rpx;
  transition: all 0.3s ease;
}

.duration-item text {
  font-size: 26rpx;
  color: #5a7a8a;
}

.duration-item.selected {
  background: #fff;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.08);
}

.duration-item.selected text {
  color: #2c3e50;
  font-weight: 600;
}

/* 开始/停止按钮 */
.action-btn {
  margin-top: 40rpx;
  padding: 20rpx 80rpx;
  background: rgba(255,255,255,0.7);
  border-radius: 40rpx;
  box-shadow: 0 2rpx 16rpx rgba(0,0,0,0.06);
  z-index: 3;
}

.action-btn text {
  font-size: 28rpx;
  color: #3a5060;
  letter-spacing: 4rpx;
}
