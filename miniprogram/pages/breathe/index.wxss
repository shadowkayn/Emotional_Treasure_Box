.container {
  min-height: 100vh;
  background-image: linear-gradient(225deg, #A9C9CA 0%, #E8F1EF 100%);
  display: flex;
  flex-direction: column;
  align-items: center;
  padding-bottom: 180rpx;
  overflow: hidden;
  position: relative;
}

/* 标题 */
.header {
  margin-top: 80rpx;
  width: 100%;
  text-align: center;
}

.title {
  font-size: 42rpx;
  font-weight: 700;
  color: #2c3e50;
  letter-spacing: 6rpx;
}

/* 呼吸球区域 */
.breath-area {
  margin-top: 100rpx;
  width: 500rpx;
  height: 500rpx;
  position: relative;
  display: flex;
  align-items: center;
  justify-content: center;
}

/* 波浪层 */
.h-wave {
  position: absolute;
  border-radius: 45%;
  opacity: 0.15;
  border: 2rpx solid rgba(255,255,255,0.4);
}

.h-wave-1 {
  width: 460rpx;
  height: 460rpx;
  background: radial-gradient(ellipse, rgba(255,255,255,0.3) 0%, transparent 70%);
}

.h-wave-2 {
  width: 500rpx;
  height: 500rpx;
  background: radial-gradient(ellipse, rgba(255,255,255,0.2) 0%, transparent 70%);
}

.h-wave-3 {
  width: 540rpx;
  height: 540rpx;
  background: radial-gradient(ellipse, rgba(255,255,255,0.15) 0%, transparent 70%);
}

.h-wave.active {
  animation-fill-mode: both;
  animation-timing-function: linear;
  animation-iteration-count: infinite;
}

.h-wave-1.active {
  animation: waveRotate1 6s linear infinite, waveBreathe 8s ease-in-out infinite;
}

.h-wave-2.active {
  animation: waveRotate2 8s linear infinite, waveBreathe 8s ease-in-out 0.5s infinite;
}

.h-wave-3.active {
  animation: waveRotate3 10s linear infinite, waveBreathe 8s ease-in-out 1s infinite;
}

@keyframes waveRotate1 {
  from { transform: rotate(0deg); }
  to   { transform: rotate(360deg); }
}

@keyframes waveRotate2 {
  from { transform: rotate(120deg); }
  to   { transform: rotate(-240deg); }
}

@keyframes waveRotate3 {
  from { transform: rotate(240deg); }
  to   { transform: rotate(600deg); }
}

@keyframes waveBreathe {
  0%, 100% {
    opacity: 0.1;
    border-radius: 45%;
  }
  25% {
    border-radius: 42% 48% 44% 46%;
  }
  50% {
    opacity: 0.3;
    border-radius: 47% 43% 46% 44%;
  }
  75% {
    border-radius: 44% 46% 42% 48%;
  }
}

/* 外层光晕 */
.glow {
  position: absolute;
  width: 420rpx;
  height: 420rpx;
  border-radius: 50%;
  background: radial-gradient(circle, rgba(255,255,255,0.6) 0%, rgba(255,255,255,0) 70%);
  transition: transform 4s ease-in-out, opacity 4s ease-in-out;
}

.glow.active {
  animation: glowPulse 8s ease-in-out infinite;
}

@keyframes glowPulse {
  0%, 100% {
    transform: scale(1);
    opacity: 0.4;
  }
  50% {
    transform: scale(1.3);
    opacity: 0.8;
  }
}

/* 呼吸球 */
.orb {
  width: 280rpx;
  height: 280rpx;
  border-radius: 50%;
  background: radial-gradient(circle at 40% 35%, rgba(255,255,255,0.95) 0%, rgba(210,230,240,0.7) 50%, rgba(180,210,225,0.4) 100%);
  box-shadow:
    0 0 60rpx rgba(255,255,255,0.8),
    0 0 120rpx rgba(200,225,240,0.4),
    inset 0 0 40rpx rgba(255,255,255,0.5);
  position: absolute;
  transition: transform 4s ease-in-out;
}

.orb.active {
  animation: orbBreathe 8s ease-in-out infinite;
}

@keyframes orbBreathe {
  0%, 100% {
    transform: scale(0.85);
    box-shadow:
      0 0 40rpx rgba(255,255,255,0.6),
      0 0 80rpx rgba(200,225,240,0.3),
      inset 0 0 30rpx rgba(255,255,255,0.4);
  }
  50% {
    transform: scale(1.15);
    box-shadow:
      0 0 80rpx rgba(255,255,255,0.9),
      0 0 160rpx rgba(200,225,240,0.5),
      inset 0 0 50rpx rgba(255,255,255,0.6);
  }
}

/* 内层光点 */
.orb-inner {
  position: absolute;
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  background: radial-gradient(circle, rgba(255,255,255,0.9) 0%, rgba(255,255,255,0) 70%);
}

.orb-inner.active {
  animation: innerPulse 8s ease-in-out infinite;
}

@keyframes innerPulse {
  0%, 100% {
    transform: scale(0.9);
    opacity: 0.6;
  }
  50% {
    transform: scale(1.2);
    opacity: 1;
  }
}

/* 提示文字 */
.hint-area {
  margin-top: 60rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  min-height: 120rpx;
}

.hint-text {
  font-size: 36rpx;
  color: #3a5060;
  letter-spacing: 6rpx;
  font-weight: 600;
  transition: opacity 0.5s ease;
  line-height: 1.8;
}

.hint-text.fade {
  opacity: 0.3;
}

.hint-text.show {
  opacity: 1;
}

/* 时长选择 */
.duration-bar {
  margin-top: 60rpx;
  display: flex;
  gap: 20rpx;
  background: rgba(255,255,255,0.5);
  border-radius: 40rpx;
  padding: 8rpx;
}

.duration-item {
  padding: 16rpx 36rpx;
  border-radius: 32rpx;
  transition: all 0.3s ease;
}

.duration-item text {
  font-size: 26rpx;
  color: #5a7a8a;
}

.duration-item.selected {
  background: #fff;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.08);
}

.duration-item.selected text {
  color: #2c3e50;
  font-weight: 600;
}

/* 开始/停止按钮 */
.action-btn {
  margin-top: 40rpx;
  padding: 20rpx 80rpx;
  background: rgba(255,255,255,0.7);
  border-radius: 40rpx;
  box-shadow: 0 2rpx 16rpx rgba(0,0,0,0.06);
}

.action-btn text {
  font-size: 28rpx;
  color: #3a5060;
  letter-spacing: 4rpx;
}
