<view class="container">
  <!-- 标题 -->
  <view class="header">
    <text class="title">{{durations[durationIndex]}}分钟极简呼吸</text>
  </view>

  <!-- 呼吸球区域 -->
  <view class="breath-area">
    <!-- 外层光晕 -->
    <view class="glow {{breathing ? 'active' : ''}}"></view>
    <!-- 呼吸球 -->
    <view class="orb {{breathing ? 'active' : ''}}"></view>
    <!-- 内层光点 -->
    <view class="orb-inner {{breathing ? 'active' : ''}}"></view>
  </view>

  <!-- 横向波浪拉丝（每条线由20个点组成波浪） -->
  <view class="silk-wave-wrap">
    <view class="silk-row silk-row-1">
      <view wx:for="{{20}}" wx:key="index" class="dot d{{index}}"></view>
    </view>
    <view class="silk-row silk-row-2">
      <view wx:for="{{20}}" wx:key="index" class="dot d{{index}}"></view>
    </view>
    <view class="silk-row silk-row-3">
      <view wx:for="{{20}}" wx:key="index" class="dot d{{index}}"></view>
    </view>
    <view class="silk-row silk-row-4">
      <view wx:for="{{20}}" wx:key="index" class="dot d{{index}}"></view>
    </view>
    <view class="silk-row silk-row-5">
      <view wx:for="{{20}}" wx:key="index" class="dot d{{index}}"></view>
    </view>
  </view>

  <!-- 呼吸提示文字 -->
  <view class="hint-area">
    <text class="hint-text" wx:if="{{!breathing}}">点击开始</text>
    <block wx:else>
      <text class="hint-text {{phase === 'inhale' ? 'show' : 'fade'}}">吸气...</text>
      <text class="hint-text {{phase === 'exhale' ? 'show' : 'fade'}}">呼气...</text>
    </block>
  </view>

  <!-- 时长选择 -->
  <view class="duration-bar">
    <view
      wx:for="{{durations}}"
      wx:key="index"
      class="duration-item {{durationIndex === index ? 'selected' : ''}}"
      bindtap="selectDuration"
      data-index="{{index}}"
    >
      <text>{{item}}分钟</text>
    </view>
  </view>

  <!-- 开始/停止按钮 -->
  <view class="action-btn" bindtap="toggleBreathing">
    <text>{{breathing ? '停止' : '开始'}}</text>
  </view>
</view>
