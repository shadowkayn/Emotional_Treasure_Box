<view class="container">
  <!-- 头部用户信息 -->
  <view class="header">
    <view class="avatar-wrap">
      <image class="avatar" src="/images/avatar.png" mode="aspectFill"></image>
    </view>
    <text class="nickname">情绪观察员</text>
  </view>

  <!-- 功能卡片 -->
  <view class="card">
    <view class="menu-item" bindtap="goToFavorites">
      <view class="menu-left">
        <text class="icon">⭐</text>
        <text class="menu-text">拾光宝盒 (收藏金句)</text>
      </view>
      <text class="arrow">›</text>
    </view>

    <view class="menu-item" bindtap="goToHistory">
      <view class="menu-left">
        <text class="icon">🗑️</text>
        <text class="menu-text">碎碎平安 (粉碎记录)</text>
      </view>
      <text class="arrow">›</text>
    </view>
  </view>

  <!-- 分享按钮 -->
  <button class="share-btn" open-type="share">
    <text>分享给共鸣的人</text>
  </button>
</view>
