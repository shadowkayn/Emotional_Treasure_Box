.container {
  position: relative;
  width: 100vw;
  height: 100vh;
  overflow: hidden;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.bg-image {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  z-index: 0;
}

/* 音乐按钮 */
.music-btn {
  position: absolute;
  top: 20rpx;
  right: 24rpx;
  width: 64rpx;
  height: 64rpx;
  z-index: 10;
  background: rgba(231, 226, 208, 0.8);
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.08);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.music-btn image {
  width: 40rpx;
  height: 40rpx;
}

.music-btn.rotating {
  animation: rotate 3s linear infinite;
}

@keyframes rotate {
  from { transform: rotate(0deg); }
  to { transform: rotate(360deg); }
}

/* 语录区域 */
.quote-wrapper {
  position: relative;
  z-index: 5;
  margin-top: 38vh;
  padding: 0 30rpx 0 180rpx;
  width: 100%;
  box-sizing: border-box;
}

.quote-text {
  font-size: 40rpx;
  font-weight: 600;
  font-style: italic;
  color: #2c2c2c;
  line-height: 1.8;
  letter-spacing: 4rpx;
  text-shadow: 0 0 5rpx rgb(99 195 11);
  font-family: ZCool, sans-serif;
}

.quote-author {
  margin-top: 40rpx;
  font-size: 32rpx;
  color: #4a4a4a;
  text-align: right;
}

/* 生成日签按钮 */
.share-btn {
  position: absolute;
  bottom: 300rpx;
  z-index: 10;
  padding: 24rpx 60rpx;
  background: rgba(255, 255, 255, 0.75);
  border-radius: 50rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.08);
  text-shadow: 0 0 1rpx #88eef1;
}

.share-btn text {
  font-size: 30rpx;
  color: #3a3a3a;
  letter-spacing: 4rpx;
  font-family: ZCool, sans-serif;
  font-weight: bold;
}


/* 日签预览弹窗 */
.card-modal {
  position: fixed;
  top: 0;
  left: 0;
  width: 100vw;
  height: 100vh;
  background: rgba(0,0,0,0.75);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  z-index: 100;
}

/* 3D翻牌容器 */
.card-flip-container {
  width: 560rpx;
  height: 996rpx;
  position: relative;
  transform-style: preserve-3d;
  transition: transform 0.8s ease-in-out;
}

.card-flip-container.flipped {
  transform: rotateY(180deg);
}

/* 卡片面 */
.card-face {
  position: absolute;
  width: 100%;
  height: 100%;
  backface-visibility: hidden;
  border-radius: 24rpx;
  overflow: hidden;
  box-shadow: 0 16rpx 48rpx rgba(0,0,0,0.4);
}

/* 卡片背面 */
.card-back {
  background: url('https://res.cloudinary.com/kayn-admin-cloud/image/upload/v1774504376/clarity-n-bk_vwvqmq.png') no-repeat;
  background-size: 100% 100%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.card-back-pattern {
  width: 480rpx;
  height: 880rpx;
  border: 4rpx solid rgba(255,255,255,0.3);
  border-radius: 20rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  background: 
    radial-gradient(circle at 30% 30%, rgba(255,255,255,0.1) 0%, transparent 50%),
    radial-gradient(circle at 70% 70%, rgba(255,255,255,0.08) 0%, transparent 50%);
}

.pattern-circle {
  width: 200rpx;
  height: 200rpx;
  border: 6rpx solid rgba(255,255,255,0.4);
  border-radius: 50%;
  margin-bottom: 60rpx;
  background: radial-gradient(circle, rgba(255,255,255,0.15) 0%, transparent 70%);
}

.pattern-text {
  font-size: 36rpx;
  color: rgba(255,255,255,0.7);
  letter-spacing: 8rpx;
}

/* 卡片正面 */
.card-front {
  transform: rotateY(180deg);
  background: #d4e4e1;
}

.card-preview {
  width: 100%;
  height: 100%;
}

.card-actions {
  margin-top: 30rpx;
  margin-bottom: 60rpx;
  animation: fadeInUp 0.5s ease-out 0.3s both;
}

@keyframes fadeInUp {
  from {
    opacity: 0;
    transform: translateY(30rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

.save-btn {
  background: #fff;
  color: #3a5060;
  font-size: 32rpx;
  padding: 24rpx 80rpx;
  border-radius: 48rpx;
  font-weight: 500;
}


/* 隐藏的画布 */
.card-canvas {
  position: fixed;
  left: -9999px;
  width: 750px;
  height: 1334px;
}
