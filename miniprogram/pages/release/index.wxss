.container {
  min-height: 100vh;
  background: #eae7de;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding-bottom: 140rpx;
}

.title {
  margin-top: 60rpx;
  font-size: 40rpx;
  font-weight: 700;
  color: #2c2c2c;
  letter-spacing: 4rpx;
}

/* 输入卡片 */
.card {
  margin-top: 40rpx;
  width: 620rpx;
  min-height: 280rpx;
  background: #fff;
  border-radius: 24rpx;
  padding: 36rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.06);
}

.input-area {
  width: 100%;
  min-height: 200rpx;
  font-size: 30rpx;
  color: #333;
  line-height: 1.8;
}

/* 碎纸机 */
.shredder-wrapper {
  margin-top: 60rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  position: relative;
}

.shredder-slot {
  width: 320rpx;
  height: 40rpx;
  background: #d6d3ca;
  border-radius: 8rpx 8rpx 0 0;
}

.shred-btn {
  width: 320rpx;
  height: 88rpx;
  background: linear-gradient(180deg, #c8d8d4 0%, #a8bfb8 100%);
  border-radius: 0 0 44rpx 44rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.1);
}

.shred-btn.disabled {
  opacity: 0.6;
  pointer-events: none;
}

.shred-btn text {
  font-size: 30rpx;
  color: #3a3a3a;
  letter-spacing: 4rpx;
}

.shred-icon {
  width: 36rpx;
  height: 36rpx;
}

/* 碎纸条 */
.paper-strips {
  position: relative;
  width: 280rpx;
  height: 0;
  overflow: visible;
}

.strip {
  position: absolute;
  top: 0;
  width: 12rpx;
  height: 0;
  background: #e8e4db;
  border-radius: 0 0 4rpx 4rpx;
  opacity: 0;
}

.paper-strips.animating .strip {
  animation: stripFall 1.2s ease-in forwards;
}

@keyframes stripFall {
  0% {
    height: 0;
    opacity: 1;
    transform: translateY(0);
  }
  30% {
    height: 180rpx;
    opacity: 1;
  }
  100% {
    height: 180rpx;
    opacity: 0;
    transform: translateY(260rpx);
  }
}

/* 碎纸堆 */
.paper-pile {
  margin-top: 20rpx;
  width: 340rpx;
  height: 80rpx;
  position: relative;
  opacity: 0;
  transition: opacity 0.5s ease;
}

.paper-pile.visible {
  opacity: 1;
}

.pile-piece {
  position: absolute;
  bottom: 0;
  width: 24rpx;
  height: 60rpx;
  background: #e8e4db;
  border-radius: 4rpx;
  transform: rotate(var(--r, 0deg));
}

.pile-piece:nth-child(1)  { left: 20rpx;  --r: -15deg; height: 50rpx; }
.pile-piece:nth-child(2)  { left: 50rpx;  --r: 10deg;  height: 65rpx; }
.pile-piece:nth-child(3)  { left: 80rpx;  --r: -8deg;  height: 55rpx; }
.pile-piece:nth-child(4)  { left: 110rpx; --r: 20deg;  height: 45rpx; }
.pile-piece:nth-child(5)  { left: 140rpx; --r: -12deg; height: 60rpx; }
.pile-piece:nth-child(6)  { left: 165rpx; --r: 5deg;   height: 50rpx; }
.pile-piece:nth-child(7)  { left: 190rpx; --r: -18deg; height: 55rpx; }
.pile-piece:nth-child(8)  { left: 215rpx; --r: 14deg;  height: 48rpx; }
.pile-piece:nth-child(9)  { left: 240rpx; --r: -6deg;  height: 62rpx; }
.pile-piece:nth-child(10) { left: 265rpx; --r: 11deg;  height: 52rpx; }
.pile-piece:nth-child(11) { left: 290rpx; --r: -20deg; height: 46rpx; }
.pile-piece:nth-child(12) { left: 310rpx; --r: 8deg;   height: 58rpx; }
